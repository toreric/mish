{
  "name": "mish-client",
  "version": "0.0.0",
  "private": true,
  "description": "Photo galleries",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toreric/mish.git"
  },
  "author": "toreric <tore.ericsson@tores.se>",
  "license": "MIT",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "homepage": "https://github.com/toreric/mish#readme",
  "scripts": {
    "build:production": "ember build --environment=production",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:prettier": "prettier . --check",
    "lint:prettier:fix": "prettier . --write",
    "start": "ember serve",
    "test": "concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\"",
    "test:ember": "ember test"
  },
  "dependencies": {
    "dialog-draggable": "^0.1.6",
    "ember-primitives": "^0.53.1",
    "ember-resources": "^7.0.7",
    "he": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/render-modifiers": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/compat": "^4.1.14",
    "@embroider/core": "^4.4.4",
    "@embroider/webpack": "^4.1.2",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@glint/core": "^1.5.2",
    "@glint/environment-ember-loose": "^1.5.2",
    "@glint/environment-ember-template-imports": "^1.5.2",
    "@glint/template": "^1.7.4",
    "@nullvoxpopuli/eslint-configs": "^5.5.0",
    "@tsconfig/ember": "^3.0.12",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^9.2.1",
    "ember-async-data": "^2.0.1",
    "ember-auto-import": "^2.12.0",
    "ember-cli": "^6.11.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-htmlbars": "^7.0.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-context-menu": "^0.5.2",
    "ember-drag-drop": "^1.0.1",
    "ember-draggable-modifiers": "^1.0.0",
    "ember-file-upload": "^9.5.0",
    "ember-focus-trap": "^1.2.0",
    "ember-intl": "^8.1.1",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-sortable": "^5.3.3",
    "ember-source": "^6.11.0",
    "ember-template-imports": "^4.4.0",
    "ember-truth-helpers": "^5.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "loader.js": "^4.7.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "tracked-built-ins": "^4.1.0",
    "webpack": "^5.105.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "ember-cli-babel": "^8.3.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/core"
      ]
    },
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild"
    ]
  },
  "engines": {
    "node": "> 20.19"
  },
  "ember": {
    "edition": "octane"
  }
}
