{
  "name": "mish-client",
  "version": "0.0.0",
  "private": true,
  "description": "Photo galleries",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toreric/mish.git"
  },
  "author": "toreric <tore.ericsson@tores.se>",
  "license": "MIT",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "homepage": "https://github.com/toreric/mish#readme",
  "scripts": {
    "build:production": "ember build --environment=production",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:prettier": "prettier . --check",
    "lint:prettier:fix": "prettier . --write",
    "start": "vite",
    "test": "concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\"",
    "test:ember": "vite build --mode development && ember test --path dist",
    "build": "vite build --watch"
  },
  "dependencies": {
    "dialog-draggable": "^0.1.6",
    "ember-primitives": "^0.59.1",
    "ember-resources": "^7.0.8",
    "he": "^1.2.0",
    "reactiveweb": "^1.9.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@ember-intl/vite": "^1.0.2",
    "@ember/optional-features": "^3.0.0",
    "@ember/render-modifiers": "^4.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.3",
    "@embroider/compat": "^4.1.20",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.6.1",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/vite": "^1.7.7",
    "@glimmer/component": "^2.1.1",
    "@glint/core": "^1.5.2",
    "@glint/environment-ember-loose": "^1.5.2",
    "@glint/environment-ember-template-imports": "^1.5.2",
    "@glint/template": "^1.7.8",
    "@nullvoxpopuli/eslint-configs": "^6.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^10.0.3",
    "decorator-transforms": "^2.3.2",
    "ember-async-data": "^2.0.1",
    "ember-cli": "^7.0.1",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-drag-drop": "^1.0.1",
    "ember-draggable-modifiers": "^1.0.0",
    "ember-file-upload": "^10.1.0",
    "ember-focus-trap": "^2.0.0",
    "ember-intl": "^8.2.7",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.1.0",
    "ember-resolver": "^13.2.0",
    "ember-sortable": "^5.3.4",
    "ember-source": "^7.0.0",
    "ember-truth-helpers": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^13.3.2",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-qunit": "^8.2.6",
    "prettier": "^3.8.4",
    "prettier-plugin-ember-template-tag": "^2.1.6",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.5.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "tracked-built-ins": "^4.1.2",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": "> 20.19"
  },
  "ember": {
    "edition": "octane"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  }
}
